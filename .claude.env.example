# Claude Code 全局切换到火山方舟 Coding Plan 的环境变量示例
# ============================================================
# 仅作人工参考，本仓库代码不会自动读取或写入本文件。
# 手工配置时，将实际 Key 填入 ANTHROPIC_AUTH_TOKEN 后，
# 按 Claude Code 官方文档写入 ~/.claude/settings.json 或
# 设置为 shell 环境变量。
#
# 注意：
# - ANTHROPIC_AUTH_TOKEN 是 Coding Plan 专属 Key，
#   不能使用普通方舟 API Key（ARK_API_KEY）。
# - 本仓库不保存、不读取、不验证任何 API Key。
# - 以下配置只在用户已把 Claude Code 整体切换到 Ark Coding Plan 时有效。

ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=kimi-k2.5
ANTHROPIC_SMALL_FAST_MODEL=kimi-k2.5

# 排障参考：
# - 400 错误：通常是 Base URL 或模型名不匹配，检查 ANTHROPIC_BASE_URL 是否指向 Coding Plan 入口。
# - 401 错误：ANTHROPIC_AUTH_TOKEN 为空或使用了错误 Key，请在控制台重新获取 Coding Plan API Key。
# - ark-code-latest 通过控制台统一管理模型版本，切换后约 3-5 分钟生效。
